# Hotel Restaurant Ordering System - Environment Variables
# Copy this file to .env and fill in your actual values

# ========== SERVER CONFIGURATION ==========
# Port on which the server will run
PORT=5000

# Environment: development, production, staging
NODE_ENV=development

# ========== DATABASE CONFIGURATION ==========
# MongoDB connection URI
# For local: mongodb://127.0.0.1:27017/hotel-ordering-db
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb://127.0.0.1:27017/hotel-ordering-db

# ========== JWT AUTHENTICATION ==========
# Secret key for signing JWT tokens (change this in production!)
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_in_production

# JWT token expiration time
# Examples: 7d (7 days), 24h (24 hours), 30d (30 days)
JWT_EXPIRE=30d

# ========== CLOUDINARY CONFIGURATION ==========
# Cloudinary cloud name from your dashboard
# Get from: https://cloudinary.com/console/settings/account
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API Key
CLOUDINARY_API_KEY=your_api_key

# Cloudinary API Secret
# IMPORTANT: Never commit this to public repositories!
CLOUDINARY_API_SECRET=your_api_secret

# ========== OPTIONAL CONFIGURATION ==========
# CORS_ORIGIN=http://localhost:3000
# LOG_LEVEL=info
